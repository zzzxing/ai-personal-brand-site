# 管理员登录信息，本地复制为 .env.local 后修改
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
ADMIN_SESSION_SECRET=please-change-to-a-long-random-string

# Neon Postgres，未配置时网站会使用默认种子数据，但后台无法持久保存
DATABASE_URL=

# 站点公开地址，用于 sitemap、Open Graph、JSON-LD
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# AI 客服：DeepSeek 服务端对话。DEEPSEEK_API_KEY 不要加 NEXT_PUBLIC_，否则会暴露到浏览器
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# AI 客服：预留 Dify 配置。当前首版聊天窗口优先走 /api/chat + DeepSeek
NEXT_PUBLIC_DIFY_EMBED_URL=
NEXT_PUBLIC_DIFY_CHATBOT_TOKEN=

# AI 客服：预留 Coze 配置。若使用 API Token，建议后续改为服务端代理，不要公开 PAT
NEXT_PUBLIC_COZE_WEB_SDK_URL=
NEXT_PUBLIC_COZE_BOT_ID=
NEXT_PUBLIC_COZE_PUBLIC_TOKEN=
